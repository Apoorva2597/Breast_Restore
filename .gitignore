# =========================
# environments / caches
# =========================
.venv/
__pycache__/
**/__pycache__/
*.pyc
.ipynb_checkpoints/

# =========================
# outputs and generated artifacts
# =========================
outputs/
**/outputs/
*.log
*.pkl
*.joblib

# =========================
# data / notes (IMPORTANT - contains PHI)
# =========================
Example Notes/
**/Example Notes/
*.txt
*.csv
*.json
*.jsonl

# =========================
# allow HuggingFace model metadata
# (needed for offline transformers inference)
# =========================
!bart_large_mnli/*.json
!bart_large_mnli/*.txt

# =========================
# local configs / secrets
# =========================
config_local.py
.env
*.key
*.pem
